    {
      "id": "57e76a7f-46dd-4b19-8af4-2afae9dd3901",
      "created_at": "2026-06-26T18:41:21.559766+00:00",
      "mode": "general",
      "text": "\u0627\u0644\u0635\u0641\u062d\u0629 \u062a\u062d\u062a\u0648\u064a \u0639\u0644\u0649 \u0645\u0642\u0627\u0631\u0646\u0629 \u0628\u064a\u0646 \u0646\u0648\u0639\u064a\u0646 \u0645\u0646 \u0627\u0644\u0645\u0633\u0627\u0644\u0643 \u0627\u0644\u0639\u0644\u0645\u064a\u0629: \u0627\u0644\u0645\u0633\u0644\u0643 \u0627\u0644\u0639\u0645\u0644\u064a \u0627\u0644\u0638\u0627\u0647\u0631\u064a \u0648\u0627\u0644\u0645\u0633\u0644\u0643 \u0627\u0644\u0639\u0645\u0644\u064a \u0627\u0644\u0642\u0627\u0639\u062f\u064a. \u0627\u0644\u063a\u0627\u064a\u0629 \u0645\u0646 \u0647\u0630\u0647 \u0627\u0644\u0635\u0641\u062d\u0629 \u0647\u064a \u0627\u0644\u0639\u0635\u0641 \u0627\u0644\u0630\u0647\u0646\u064a \u0648\u062a\u0646\u0638\u064a\u0645 \u0627\u0644\u0645\u0639\u0644\u0648\u0645\u0627\u062a \u0628\u0637\u0631\u064a\u0642\u0629 \u0648\u0627\u0636\u062d\u0629\u060c \u062a\u0633\u0647\u0644 \u0641\u0647\u0645 \u0627\u0644\u0641\u0631\u0648\u0642\u0627\u062a \u0628\u064a\u0646 \u0627\u0644\u0645\u0633\u0644\u0643\u064a\u0646. **\u062a\u0641\u0627\u0635\u064a\u0644 \u0627\u0644\u0645\u062d\u062a\u0648\u0649:** 1. **\u0627\u0644\u0645\u0633\u0644\u0643 \u0627\u0644\u0639\u0645\u0644\u064a \u0627\u0644\u0638\u0627\u0647\u0631\u064a**: \u064a\u0633\u062a\u0639\u0631\u0636 \u0643\u064a\u0641\u064a\u0629 \u0627\u0644\u0627\u0633\u062a\u0646\u062a\u0627\u062c \u0648\u0641\u0647\u0645 \u0627\u0644\u0638\u0648\u0627\u0647\u0631 \u0627\u0644\u0637\u0628\u064a\u0639\u064a\u0629 \u0648\u0627\u0644\u062a\u0645\u064a\u064a\u0632 \u0628\u064a\u0646\u0647\u0627. 2. **\u0627\u0644\u0645\u0633\u0644\u0643 \u0627\u0644\u0639\u0645\u0644\u064a \u0627\u0644\u0642\u0627\u0639\u062f\u064a**: \u064a\u0631\u0643\u0632 \u0639\u0644\u0649 \u0627\u0644\u0645\u0641\u0627\u0647\u064a\u0645 \u0627\u0644\u0623\u0633\u0627\u0633\u064a\u0629 \u0648\u0637\u0631\u0642 \u062a\u062d\u0644\u064a\u0644 \u0627\u0644\u0646\u062a\u0627\u0626\u062c. \u062a\u062a\u0636\u0645\u0646 \u0627\u0644\u0635\u0641\u062d\u0629 \u0623\u064a\u0636\u064b\u0627 \u0646\u0642\u0627\u0637 \u062a\u0639\u0644\u064a\u0645\u064a\u0629 \u062a\u0633\u0627\u0639\u062f \u0627\u0644\u0637\u0644\u0628\u0629 \u0639\u0644\u0649 \u0641\u0647\u0645 \u0627\u0644\u0639\u0644\u0627\u0642\u0629 \u0628\u064a\u0646 \u0627\u0644\u0638\u0648\u0627\u0647\u0631 \u0627\u0644\u0639\u0644\u0645\u064a\u0629 \u0648\u0643\u064a\u0641\u064a\u0629 \u062a\u0637\u0628\u064a\u0642 \u0627\u0644\u0645\u0639\u0631\u0641\u0629. \u062f\u0648\u0631 \u0647\u0630\u0647 \u0627\u0644\u0635\u0641\u062d\u0629 \u0647\u0648 \u062a\u0648\u0636\u064a\u062d \u0627\u0644\u0645\u0641\u0627\u0647\u064a\u0645 \u0648\u062a\u0642\u062f\u064a\u0645 \u0642\u0627\u0639\u062f\u0629 \u0645\u0639\u0631\u0641\u064a\u0629 \u0644\u0644\u0637\u0644\u0627\u0628\u060c \u0645\u0645\u0627 \u064a\u0633\u0647\u0645 \u0641\u064a \u062a\u0639\u0632\u064a\u0632 \u0641\u0647\u0645\u0647\u0645 \u0644\u0644\u0645\u0648\u0627\u062f \u0627\u0644\u0639\u0644\u0645\u064a\u0629."
    },
    {
      "id": "fa6e4615-85ef-4021-b4f6-095cf32a7fd9",
      "created_at": "2026-06-26T18:15:40.311769+00:00",
      "mode": "medical",
      "text": "\u0642\u0627\u0646\u0648\u0646 \u0641\u064a\u062b\u0627\u063a\u0648\u0631\u0633 \u064a\u0646\u0635 \u0639\u0644\u0649 \u0623\u0646 \u0641\u064a \u0623\u064a \u0645\u062b\u0644\u062b \u0642\u0627\u0626\u0645 \u0627\u0644\u0632\u0627\u0648\u064a\u0629\u060c \u0645\u0631\u0628\u0639 \u0637\u0648\u0644 \u0627\u0644\u0648\u062a\u0631 \u064a\u0633\u0627\u0648\u064a \u0645\u062c\u0645\u0648\u0639 \u0645\u0631\u0628\u0639\u064a \u0637\u0648\u0644\u064a \u0627\u0644\u0636\u0644\u0639\u064a\u0646 \u0627\u0644\u0622\u062e\u0631\u064a\u0646. \u0628\u0645\u0639\u0646\u0649 \u0622\u062e\u0631\u060c \u0625\u0630\u0627 \u0643\u0627\u0646 \u0644\u062f\u064a\u0646\u0627 \u0645\u062b\u0644\u062b \u0642\u0627\u0626\u0645 \u0627\u0644\u0632\u0627\u0648\u064a\u0629 \u062d\u064a\u062b \u0623\u0637\u0648\u0627\u0644 \u0627\u0644\u0636\u0644\u0639\u064a\u0646 \u0627\u0644\u0642\u0627\u0626\u0645\u064a\u0646 \u0647\u0645\u0627 \\( a \\) \u0648 \\( b \\) \u0648\u0637\u0648\u0644 \u0627\u0644\u0648\u062a\u0631 \u0647\u0648 \\( c \\)\u060c \u0641\u0625\u0646 \u0627\u0644\u0635\u064a\u063a\u0629 \u0647\u064a: \\[ c^2 = a^2 + b^2 \\] \u0647\u0630\u0627 \u064a\u0639\u0646\u064a \u0623\u0646\u0647 \u0625\u0630\u0627 \u0643\u0646\u062a \u062a\u0639\u0631\u0641 \u0637\u0648\u0644 \u0627\u0644\u0636\u0644\u0639\u064a\u0646 \u0627\u0644\u0622\u062e\u0631\u064a\u0646\u060c \u064a\u0645\u0643\u0646\u0643 \u062d\u0633\u0627\u0628 \u0637\u0648\u0644 \u0627\u0644\u0648\u062a\u0631. \u0647\u0644 \u0644\u062f\u064a\u0643 \u0623\u064a \u0623\u0633\u0626\u0644\u0629 \u0625\u0636\u0627\u0641\u064a\u0629\u061f"
    }
  ]
